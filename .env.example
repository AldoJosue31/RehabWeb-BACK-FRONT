MYSQL_DATABASE=rehab_db
MYSQL_USER=rehab_user
MYSQL_PASSWORD=rehab_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST=db
MYSQL_PORT=3306

DJANGO_SECRET_KEY=rehabweb-local-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,IP_DE_ESTA_PC
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://IP_DE_ESTA_PC:4200,https://localhost:4200,https://127.0.0.1:4200,https://IP_DE_ESTA_PC:4200,http://frontend:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://IP_DE_ESTA_PC:4200,https://localhost:4200,https://127.0.0.1:4200,https://IP_DE_ESTA_PC:4200
FRONTEND_ALLOWED_HOSTS=localhost,127.0.0.1,IP_DE_ESTA_PC
FRONTEND_HTTPS=true
FRONTEND_LAN_IP=IP_DE_ESTA_PC

# Para que el terapeuta entre automaticamente como anfitrion en Jitsi,
# usa Jitsi as a Service (8x8.vc) o un Jitsi propio con JWT.
JITSI_DOMAIN=8x8.vc
JITSI_APP_ID=
JITSI_KID=
JITSI_PRIVATE_KEY=
JITSI_JWT_ISSUER=chat
JITSI_JWT_TTL_SECONDS=7200
